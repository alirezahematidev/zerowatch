{
  "name": "zerowatch",
  "version": "0.1.2",
  "description": "A modern, zero-dependency file watcher for Node.js",
  "type": "module",
  "license": "MIT",
  "author": "Alireza Hemmati <alirezahematideveloper71@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alirezahematidev/zerowatch.git"
  },
  "bugs": {
    "url": "https://github.com/alirezahematidev/zerowatch/issues"
  },
  "homepage": "https://github.com/alirezahematidev/zerowatch#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "yarn run build && node bench/index.ts",
    "release": "release-it",
    "prepublishOnly": "yarn run build"
  },
  "keywords": [
    "watch",
    "watcher",
    "file",
    "fs",
    "filesystem",
    "chokidar",
    "fsevents",
    "async-iterator",
    "esm",
    "typescript"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@parcel/watcher": "^2.5.6",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "4.1.10",
    "chokidar": "^5.0.0",
    "release-it": "^20.2.1",
    "sane": "^5.0.1",
    "tinybench": "^6.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vite": "^8.1.4",
    "vitest": "4.1.10",
    "watchpack": "^2.5.2"
  }
}
